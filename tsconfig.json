{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/app/*": ["./src/app/*"],
      "@/features/*": ["./src/features/*"],
      "@/features/authentication/*": ["./src/features/authentication/*"],
      "@/features/pre-order/*": ["./src/features/pre-order/*"],
      "@/features/trademark-application/*": ["./src/features/trademark-application/*"],
      "@/features/trademark-analysis/*": ["./src/features/trademark-analysis/*"],
      "@/infrastructure/*": ["./src/infrastructure/*"],
      "@/shared/*": ["./src/shared/*"],
      "@/shared/components/*": ["./src/shared/components/*"],
      "@/shared/hooks/*": ["./src/shared/hooks/*"],
      "@/shared/types/*": ["./src/shared/types/*"],
      "@/shared/utils/*": ["./src/shared/utils/*"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
