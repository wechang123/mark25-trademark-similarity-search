// 서버 전용 키프리스 API 모듈 (ES modules 호환)

export interface KiprisTrademarkInfo {
  serialNumber?: string
  applicationNumber?: string
  appReferenceNumber?: string
  applicationDate?: string
  publicNumber?: string
  publicDate?: string
  registrationPublicNumber?: string
  registrationPublicDate?: string
  registrationNumber?: string
  regReferenceNumber?: string
  registrationDate?: string
  priorityClaimNumber?: string
  priorityClaimDate?: string
  internationalRegisterNumber?: string
  internationalRegisterDate?: string
  applicationStatus?: string
  goodsClassificationCode?: string
  applicantName?: string
  agentName?: string
  registrationRightholderName?: string
  title?: string // 이게 실제 상표명
  fulltextExistFlag?: string
  imagePath?: string
  thumbnailPath?: string
  similarityScore?: number // 계산된 유사도
  riskLevel?: "LOW" | "MEDIUM" | "HIGH"
  rejectionReason?: string // 거절 사유 (전체)
  rejectionReasonSummary?: string // 거절 사유 (한 줄 요약)
  legalGround?: string // 법적 근거
  pdfFileUrl?: string // PDF 파일 URL
  docName?: string // 문서명
  /**
   * 이 항목이 유사군 코드 검색으로 매칭되었을 때, 적용된 유사군 코드 목록
   */
  matchedSimilarCodes?: string[]
  /**
   * KIPRIS API로부터 조회한 해당 상표의 실제 유사군 코드 목록
   */
  similarityCodes?: string[]
  rejectionInfo?: {
    rejectionDate?: string
    rejectionReasons?: string[]
    decisionNumber?: string
    appealStatus?: string
    finalDecision?: string
  }
}

export interface KiprisSearchResult {
  total: number;
  items: KiprisTrademarkInfo[];
  sameIndustryCount: number;
  riskScore: number;
  riskLevel: "low" | "medium" | "high";
  searchQuery: string;
  searchTimestamp: string;
}

// -----------------------------
// Optimization: in-memory cache & quota cooldown
// -----------------------------
type RejectionCacheData = {
  rejectionReason?: string;
  rejectionReasonSummary?: string;
  legalGround?: string;
  rejectionDate?: string;
  decisionNumber?: string;
  documentType?: string;
  filePath?: string;
  pdfFileUrl?: string;
  docName?: string;
  rejectionDetails?: {
    rejectionType: string;
    rejectionReasons: string[];
    decisionAuthority: string;
    appealDeadline?: string;
    nextSteps?: string;
  };
};

const rejectionInfoCache = new Map<string, { cachedAt: number; data: RejectionCacheData }>();
const REJECTION_CACHE_TTL_MS = 24 * 60 * 60 * 1000; // 24 hours

let kiprisQuotaCooldownUntil = 0; // epoch ms
function setQuotaCooldown(minutes: number) {
  const until = Date.now() + minutes * 60 * 1000;
  kiprisQuotaCooldownUntil = Math.max(kiprisQuotaCooldownUntil, until);
}

// 🆕 Similarity code search cache (24h)
type SimilarityCacheEntry = { cachedAt: number; items: KiprisTrademarkInfo[] };
type SimilarityCodeCacheEntry = { cachedAt: number; codes: string[] };
const similarityCodeCache = new Map<string, SimilarityCacheEntry>();
const similarityCodeFetchCache = new Map<string, SimilarityCodeCacheEntry>();
const SIMILARITY_CACHE_TTL_MS = 24 * 60 * 60 * 1000; // 24 hours

export async function searchKiprisTrademarks(
  trademark: string,
  productClassificationCodes: string[],
  similarGroupCodes: string[],
  designatedProducts: string[],
): Promise<KiprisSearchResult> {
  const searchTimestamp = new Date().toISOString();

  console.log(`🔍 [KIPRIS] Starting search for "${trademark}"`);

  // 안전한 문자열 처리
  const safeTrademark = (trademark || "").toString().trim();

  if (!safeTrademark) {
    throw new Error("Invalid trademark parameter");
  }

  // 환경변수 검증
  const kiprisKey = process.env.KIPRIS_SEARCH_API_KEY || process.env.KIPRIS_API_KEY;

  if (!kiprisKey || kiprisKey.trim() === "") {
    console.error("❌ [SERVER] KIPRIS_SEARCH_API_KEY or KIPRIS_API_KEY is missing or empty");
    throw new Error("KIPRIS API key environment variable is not set or empty. Please configure your API key.");
  }

  console.log(`🚀 [KIPRIS] API key validated`);

  try {
    let searchResults: KiprisTrademarkInfo[] = [];

    // PARALLEL EXECUTION: Run free search and trademark name search simultaneously
    console.log(`🔄 [KIPRIS] Starting parallel searches (free + trademark name)...`);
    
    const searchPromises: Promise<KiprisTrademarkInfo[]>[] = [
      // 1. Free search (자유 검색)
      performKiprisFreeSearch(safeTrademark, kiprisKey),
      // 2. Trademark name search (상표 명칭 검색)
      performKiprisNameSearch(safeTrademark, kiprisKey)
    ];

    // Execute all searches in parallel
    const allSearchResults = await Promise.all(searchPromises);
    
    // Combine all results
    const combinedResults = allSearchResults.flat();
    console.log(`📊 [KIPRIS] Combined ${combinedResults.length} results from parallel searches`);

    // Remove duplicates
    searchResults = removeDuplicateTrademarks(combinedResults);

    // Filter by similar group codes if provided
    if (similarGroupCodes && similarGroupCodes.length > 0) {
      searchResults = filterBySimilarGroupCodes(searchResults, similarGroupCodes);
    }

    // 3. If we have application numbers, get similarity codes for each trademark
    if (searchResults.length > 0) {
      console.log(`🔍 [KIPRIS] Fetching similarity codes for ${searchResults.length} trademarks...`);
      const resultsWithSimilarityCodes = await fetchSimilarityCodesForTrademarks(searchResults, kiprisKey);
      searchResults = resultsWithSimilarityCodes;
    }

    // 결과 분석 및 변환
    const analyzedResults = analyzeKiprisResults(
      searchResults,
      safeTrademark,
      productClassificationCodes,
      similarGroupCodes,
      designatedProducts,
      searchTimestamp
    );
    
    console.log(`✅ [KIPRIS] Search completed: ${searchResults.length} final results`);
    return analyzedResults;

  } catch (error) {
    console.error('❌ [KIPRIS] Search failed:', error);
    throw error;
  }
}

/**
 * 키프리스 getWordSearch API 호출 함수
 */
async function performKiprisWordSearch(
  trademark: string,
  kiprisKey: string
): Promise<KiprisTrademarkInfo[]> {
  console.log(`🔍 [KIPRIS] Calling getWordSearch API for "${trademark}"`);
  
  const url = `http://plus.kipris.or.kr/kipo-api/kipi/trademarkInfoSearchService/getWordSearch`;
  const params = new URLSearchParams({
    searchString: trademark,
    searchRecentYear: '0', // 전체 기간 검색
    ServiceKey: kiprisKey
  });

  try {
    const response = await fetch(`${url}?${params.toString()}`, {
      method: 'GET',
      headers: {
        'User-Agent': 'IP-Doctor/1.0',
      },
    });

    if (!response.ok) {
      throw new Error(`HTTP ${response.status}: ${response.statusText}`);
    }

    const xmlText = await response.text();
    console.log(`📄 [KIPRIS] Received XML response, length: ${xmlText.length}`);

    // XML 파싱
    const items = parseKiprisWordSearchXML(xmlText);
    console.log(`✅ [KIPRIS] Parsed ${items.length} items from XML`);

    return items;

  } catch (error) {
    console.error('❌ [KIPRIS] getWordSearch API call failed:', error);
    throw error;
  }
}

/**
 * Perform exact name search using KIPRIS API
 * This searches for exact trademark name matches
 */
async function performExactNameSearch(
  trademark: string,
  kiprisKey: string
): Promise<KiprisTrademarkInfo[]> {
  console.log(`🔍 [KIPRIS] Calling exact name search for "${trademark}"`);
  
  const url = `http://plus.kipris.or.kr/kipo-api/kipi/trademarkInfoSearchService/getAdvancedSearch`;
  const params = new URLSearchParams({
    trademarkName: trademark, // Exact name search
    searchRecentYear: '0', // 전체 기간 검색
    ServiceKey: kiprisKey
  });

  try {
    const response = await fetch(`${url}?${params.toString()}`, {
      method: 'GET',
      headers: {
        'User-Agent': 'IP-Doctor/1.0',
      },
    });

    if (!response.ok) {
      throw new Error(`HTTP ${response.status}: ${response.statusText}`);
    }

    const xmlText = await response.text();
    console.log(`📄 [KIPRIS] Received exact name search XML response, length: ${xmlText.length}`);

    // Parse XML - reuse existing parser
    const items = parseKiprisAdvancedXML(xmlText);
    console.log(`✅ [KIPRIS] Parsed ${items.length} items from exact name search`);

    return items;

  } catch (error) {
    console.error('❌ [KIPRIS] Exact name search failed:', error);
    // Return empty array on failure to allow other searches to continue
    return [];
  }
}

/**
 * Remove duplicate trademarks based on application number
 */
function removeDuplicateTrademarks(trademarks: KiprisTrademarkInfo[]): KiprisTrademarkInfo[] {
  const seen = new Set<string>();
  const unique: KiprisTrademarkInfo[] = [];
  
  for (const trademark of trademarks) {
    const key = trademark.applicationNumber;
    if (!seen.has(key)) {
      seen.add(key);
      unique.push(trademark);
    }
  }
  
  console.log(`🧹 [KIPRIS] Removed ${trademarks.length - unique.length} duplicates, ${unique.length} unique results`);
  return unique;
}

/**
 * Filter trademarks by matching similar group codes
 */
function filterBySimilarGroupCodes(
  trademarks: KiprisTrademarkInfo[], 
  targetCodes: string[]
): KiprisTrademarkInfo[] {
  if (!targetCodes || targetCodes.length === 0) {
    return trademarks;
  }
  
  const filtered = trademarks.filter(trademark => {
    // Check if any of the trademark's similar group codes match our target codes
    const trademarkCodes = trademark.similarityCode?.split(',').map(c => c.trim()) || [];
    return trademarkCodes.some(code => targetCodes.includes(code));
  });
  
  console.log(`🎯 [KIPRIS] Filtered to ${filtered.length}/${trademarks.length} trademarks with matching similar group codes`);
  return filtered;
}

/**
 * Fetch similarity codes for trademarks using trademarkSimilarityCodeInfo API
 */
async function fetchSimilarityCodesForTrademarks(
  trademarks: KiprisTrademarkInfo[], 
  kiprisKey: string
): Promise<KiprisTrademarkInfo[]> {
  console.log(`🔍 [KIPRIS] Fetching similarity codes for ${trademarks.length} trademarks`);
  
  const updatedTrademarks = await Promise.all(
    trademarks.map(async (trademark) => {
      if (!trademark.applicationNumber) {
        return trademark;
      }
      
      try {
        const apiUrl = `http://plus.kipris.or.kr/openapi/rest/trademarkInfoSearchService/trademarkSimilarityCodeInfo`;
        const params = new URLSearchParams({
          applicationNumber: trademark.applicationNumber,
          accessKey: kiprisKey
        });
        
        const response = await fetch(`${apiUrl}?${params.toString()}`, {
          method: 'GET',
          headers: {
            'Accept': 'application/json',
            'User-Agent': 'IP-Doctor/1.0'
          }
        });
        
        if (response.ok) {
          const data = await response.json();
          // Extract similarity codes from response and add to trademark
          if (data.response?.body?.items?.item) {
            const items = Array.isArray(data.response.body.items.item) 
              ? data.response.body.items.item 
              : [data.response.body.items.item];
            
            const similarityCodes = items
              .map((item: any) => item.similarityCode)
              .filter(Boolean)
              .join(',');
            
            return {
              ...trademark,
              similarityCode: similarityCodes || trademark.similarityCode
            };
          }
        }
      } catch (error) {
        console.warn(`⚠️ [KIPRIS] Failed to fetch similarity codes for ${trademark.applicationNumber}:`, error);
      }
      
      return trademark;
    })
  );
  
  console.log(`✅ [KIPRIS] Similarity codes fetched for trademarks`);
  return updatedTrademarks;
}

/**
 * getWordSearch XML 응답 파싱 함수
 */
function parseKiprisWordSearchXML(xmlText: string): KiprisTrademarkInfo[] {
  const items: KiprisTrademarkInfo[] = [];
  
  try {
    // XML에서 <item> 태그들을 추출
    const itemMatches = xmlText.match(/<item>([\s\S]*?)<\/item>/g);
    
    if (!itemMatches) {
      console.warn('⚠️ [KIPRIS] No <item> tags found in XML response');
      return items;
    }

    for (const itemXml of itemMatches) {
      try {
        const item = parseKiprisItemXML(itemXml);
        if (item) {
          items.push(item);
        }
      } catch (itemError) {
        console.warn('⚠️ [KIPRIS] Failed to parse item XML:', itemError);
      }
    }

    console.log(`✅ [KIPRIS] Successfully parsed ${items.length} items`);
    return items;

  } catch (error) {
    console.error('❌ [KIPRIS] XML parsing failed:', error);
    return items;
  }
}

/**
 * 개별 상표 아이템 XML 파싱 함수
 */
function parseKiprisItemXML(itemXml: string): KiprisTrademarkInfo | null {
  try {
    const extractValue = (tagName: string): string => {
      const regex = new RegExp(`<${tagName}>([^<]*)</${tagName}>`);
      const match = itemXml.match(regex);
      return match ? match[1].trim() : '';
    };

    const item: KiprisTrademarkInfo = {
      serialNumber: extractValue('indexNo'),
      applicationNumber: extractValue('applicationNumber'),
      applicationDate: extractValue('applicationDate'),
      publicNumber: extractValue('publicationNumber'),
      publicDate: extractValue('publicationDate'),
      registrationPublicNumber: extractValue('registrationPublicNumber'),
      registrationPublicDate: extractValue('registrationPublicDate'),
      registrationNumber: extractValue('registrationNumber'),
      registrationDate: extractValue('registrationDate'),
      priorityClaimNumber: extractValue('priorityNumber'),
      priorityClaimDate: extractValue('priorityDate'),
      applicationStatus: extractValue('applicationStatus'),
      goodsClassificationCode: extractValue('classificationCode'),
      applicantName: extractValue('applicantName'),
      agentName: extractValue('agentName'),
      registrationRightholderName: extractValue('regPrivilegeName'),
      title: extractValue('title'),
      fulltextExistFlag: extractValue('fullText'),
      imagePath: extractValue('drawing'),
      thumbnailPath: extractValue('bigDrawing'),
      similarityScore: 0, // 기본값, 나중에 계산
      riskLevel: 'LOW' as const, // 기본값, 나중에 계산
    };

    // 필수 필드 검증
    if (!item.title || !item.applicationNumber) {
      console.warn('⚠️ [KIPRIS] Item missing required fields:', { title: item.title, applicationNumber: item.applicationNumber });
      return null;
    }

    return item;

  } catch (error) {
    console.error('❌ [KIPRIS] Item XML parsing failed:', error);
    return null;
  }
}

/**
 * 유사군 코드 직접 검색 API (similarityCodesearchInfo)
 * 문서: /openapi/rest/trademarkInfoSearchService/similarityCodesearchInfo
 */
async function performSimilarityCodeSearch(
  similarGroupCodes: string[],
  kiprisKey: string,
  docsStart: number = 1,
  docsCount: number = 100,
): Promise<KiprisTrademarkInfo[]> {
  const cacheKey = `${similarGroupCodes.sort().join('|')}|${docsStart}|${docsCount}`;
  const cached = similarityCodeCache.get(cacheKey);
  if (cached && Date.now() - cached.cachedAt < SIMILARITY_CACHE_TTL_MS) {
    console.log(`🗃️ [KIPRIS] Using cached similarityCodesearchInfo: ${similarGroupCodes.length} codes`);
    return cached.items.map(i => ({ ...i, matchedSimilarCodes: [...(i.matchedSimilarCodes || []), ...similarGroupCodes] }));
  }
  // 유사군 코드를 파이프(|)로 연결
  const similarityCodeParam = similarGroupCodes.join('|');
  const baseUrls = [
    'https://plus.kipris.or.kr/openapi/rest/trademarkInfoSearchService/similarityCodesearchInfo',
    'http://plus.kipris.or.kr/openapi/rest/trademarkInfoSearchService/similarityCodesearchInfo',
  ];

  for (const baseUrl of baseUrls) {
    try {
      const url = `${baseUrl}?similarityCode=${encodeURIComponent(similarityCodeParam)}&docsStart=${docsStart}&docsCount=${docsCount}&accessKey=${kiprisKey}`;
      console.log(`🔍 [KIPRIS] similarityCodesearchInfo URL: ${url.replace(kiprisKey, '***')}`);

      const response = await fetch(url);
      if (!response.ok) {
        console.warn(`⚠️ [KIPRIS] similarityCodesearchInfo HTTP ${response.status}`);
        continue;
      }

      const xmlText = await response.text();
      // 응답 파싱
      const items = parseSimilarityCodeXML(xmlText);
      // 매칭된 유사군 코드 메타태그 추가
      items.forEach(i => { i.matchedSimilarCodes = [...similarGroupCodes]; });
      if (items.length > 0) {
        similarityCodeCache.set(cacheKey, { cachedAt: Date.now(), items });
        return items;
      }
    } catch (err) {
      console.warn('⚠️ [KIPRIS] similarityCodesearchInfo request failed:', err);
    }
  }

  return [];
}

function parseSimilarityCodeXML(xmlText: string): KiprisTrademarkInfo[] {
  try {
    const resultCodeMatch = xmlText.match(/<resultCode>(.*?)<\/resultCode>/);
    const resultCode = resultCodeMatch ? resultCodeMatch[1] : '';
    if (resultCode && resultCode !== '00') {
      console.warn(`[KIPRIS] similarityCodesearchInfo resultCode=${resultCode}`);
    }

    const tradeMarkInfoBlocks = xmlText.match(/<TradeMarkInfo>([\s\S]*?)<\/TradeMarkInfo>/g);
    if (!tradeMarkInfoBlocks) return [];

    const items: KiprisTrademarkInfo[] = [];
    for (const block of tradeMarkInfoBlocks) {
      const item: KiprisTrademarkInfo = {
        serialNumber: extractXMLValue(block, 'SerialNumber'),
        applicationNumber: extractXMLValue(block, 'ApplicationNumber'),
        appReferenceNumber: extractXMLValue(block, 'AppReferenceNumber'),
        applicationDate: formatDate(extractXMLValue(block, 'ApplicationDate')),
        publicNumber: extractXMLValue(block, 'PublicNumber'),
        publicDate: formatDate(extractXMLValue(block, 'PublicDate')),
        registrationPublicNumber: extractXMLValue(block, 'RegistrationPublicNumber'),
        registrationPublicDate: formatDate(extractXMLValue(block, 'RegistrationPublicDate')),
        registrationNumber: extractXMLValue(block, 'RegistrationNumber'),
        regReferenceNumber: extractXMLValue(block, 'RegReferenceNumber'),
        registrationDate: formatDate(extractXMLValue(block, 'RegistrationDate')),
        priorityClaimNumber: extractXMLValue(block, 'PriorityClaimNumber'),
        priorityClaimDate: formatDate(extractXMLValue(block, 'PriorityClaimDate')),
        internationalRegisterNumber: extractXMLValue(block, 'InternationalRegisterNumber'),
        internationalRegisterDate: formatDate(extractXMLValue(block, 'InternationalRegisterDate')),
        applicationStatus: extractXMLValue(block, 'ApplicationStatus'),
        goodsClassificationCode: extractXMLValue(block, 'GoodClassificationCode'),
        applicantName: extractXMLValue(block, 'ApplicantName'),
        agentName: extractXMLValue(block, 'AgentName'),
        registrationRightholderName: extractXMLValue(block, 'RegistrationRightholderName'),
        title: extractXMLValue(block, 'Title'),
        fulltextExistFlag: extractXMLValue(block, 'FulltextExistFlag'),
        imagePath: extractXMLValue(block, 'ImagePath'),
        thumbnailPath: extractXMLValue(block, 'ThumbnailPath'),
        similarityScore: 0,
        riskLevel: 'LOW',
      };
      if (item.title && (item.applicationNumber || item.appReferenceNumber)) {
        items.push(item);
      }
    }
    return items;
  } catch (e) {
    console.warn('⚠️ [KIPRIS] Failed to parse similarityCodesearchInfo XML:', e);
    return [];
  }
}
async function performKiprisSearchFixed(
  trademark: string,
  productClassificationCodes: string[],
  similarGroupCodes: string[],
  designatedProducts: string[],
  kiprisKey: string,
): Promise<KiprisTrademarkInfo[]> {
  // Advanced Search 실행 with enhanced filtering

  const allResults: KiprisTrademarkInfo[] = [];

  // HTTPS를 먼저 시도하고, 실패하면 HTTP 시도
  const baseUrls = [
    "https://plus.kipris.or.kr/kipo-api/kipi/trademarkInfoSearchService/getAdvancedSearch",
    "http://plus.kipris.or.kr/kipo-api/kipi/trademarkInfoSearchService/getAdvancedSearch",
  ];

  for (const baseUrl of baseUrls) {
    // Base URL 시도 중
    
    try {
      let url = `${baseUrl}?ServiceKey=${kiprisKey}`;

      // 상표명칭 (trademarkName)
      if (trademark) {
        url += `&trademarkName=${encodeURIComponent(trademark)}`;
      }

      // 상품분류코드 (classification) - 모든 분류번호 사용
      if (productClassificationCodes && productClassificationCodes.length > 0) {
        // 모든 분류번호를 파이프(|)로 연결하여 전송
        const classificationParam = productClassificationCodes.join("|");
        url += `&classification=${encodeURIComponent(classificationParam)}`;
        console.log(`🔍 [SERVER] Using classification codes: ${productClassificationCodes.join(", ")}`);
        console.log(`🔍 [SERVER] Classification parameter: ${classificationParam}`);
      }

      // 🎯 유사군 코드 필터링 활성화 (Stage 1에서 받은 코드들 사용)
      if (similarGroupCodes && similarGroupCodes.length > 0) {
        const similarGroupParam = similarGroupCodes.join("|");
        url += `&similarGroupCode=${encodeURIComponent(similarGroupParam)}`;
        console.log(`🎯 [SERVER] Using similar group codes: ${similarGroupCodes.join(", ")}`);
      }

      // 🔧 등록 가능성 판단에 필요한 상태만 필터링 ('등록, 출원중, 공고중, 심사중, 심판중')
      // registration=등록, application=출원중, publication=공고중, examination=심사중, trial=심판중
      url += `&application=true&registration=true&publication=true&examination=true&trial=true`;
      // 제외할 상태들: refused=거절, expiration=소멸, withdrawal=포기, cancel=취소, abandonment=포기
      url += `&refused=false&expiration=false&withdrawal=false&cancel=false&abandonment=false`;
      
      console.log(`🚀 [SERVER] Status filtering: Only relevant statuses (등록, 출원중, 공고중, 심사중, 심판중)`);

      // 기타 고정 파라미터
      url += `&trademark=true&serviceMark=true&businessEmblem=true&collectiveMark=true&geoOrgMark=true&trademarkServiceMark=true&certMark=true&geoCertMark=true&internationalMark=true&character=true&figure=true&compositionCharacter=true&figureComposition=true&fragrance=true&sound=true&color=true&colorMixed=true&dimension=true&hologram=true&invisible=true&motion=true&visual=true`;
      url += `&docsStart=1&docsCount=100`; // 결과 수 제한

      // API 호출 (로그 간소화)

      const controller = new AbortController();
      const timeoutId = setTimeout(() => {
        console.log(`⏰ [SERVER] Request timeout for KIPRIS advanced search`);
        controller.abort();
      }, 60000); // 60초 타임아웃

      const response = await fetch(url, {
        method: "GET",
        headers: {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
          "Accept": "application/xml, text/xml, */*",
          "Accept-Language": "ko-KR,ko;q=0.9,en;q=0.8",
          "Accept-Encoding": "gzip, deflate, br",
          "Cache-Control": "no-cache",
          "Connection": "keep-alive",
          "Upgrade-Insecure-Requests": "1"
        },
        signal: controller.signal,
      });

      clearTimeout(timeoutId);

      console.log(`📡 [SERVER] Fetch request completed`);
      console.log(`📡 [SERVER] Response status: ${response.status} ${response.statusText}`);

      if (!response.ok) {
        console.error(`❌ [SERVER] HTTP error: ${response.status} ${response.statusText}`);
        const errorText = await response.text();
        console.error("❌ [SERVER] Error response body:", errorText.substring(0, 500));
        throw new Error(`KIPRIS API HTTP error: ${response.status} ${response.statusText}`);
      }

      const xmlText = await response.text();
      // XML 응답 수신됨
      
      // 응답 코드 확인
      const resultCodeMatch = xmlText.match(/<resultCode>(.*?)<\/resultCode>/);
      if (resultCodeMatch && resultCodeMatch[1] !== "00") {
        console.log(`📋 [SERVER] KIPRIS Response Code: "${resultCodeMatch[1]}"`);
      }

      if (!xmlText || xmlText.length < 50) {
        console.warn(`⚠️ [SERVER] Empty or too short response for advanced search`);
        return []; // 결과 없음
      }

      // XML 파싱 및 데이터 추출
      const items = parseKiprisXMLImproved(xmlText);
      // Advanced search 파싱 완료

      if (items.length > 0) {
        // 🎯 추가 유사군 코드 매칭 필터링
        const filteredItems = await filterBySimilarityCode(items, similarGroupCodes);
        
        allResults.push(...filteredItems);
        console.log(`✅ [SERVER] Got ${items.length} raw results, ${filteredItems.length} after similarity filtering`);
        break; // 첫 번째 URL에서 결과를 얻으면 충분
      }

      // API 호출 간격 (필요시)
      await new Promise((resolve) => setTimeout(resolve, 1000));

    } catch (error) {
      console.error(`❌ [SERVER] Request failed for KIPRIS advanced search:`, error);

      if (error instanceof Error && error.name === "AbortError") {
        console.error(`⏰ [SERVER] Request timeout for KIPRIS advanced search`);
      }

      continue; // 다음 URL 시도
    }
  }

  // 중복 제거
  const uniqueResults = removeDuplicateTrademarks(allResults);
  console.log(`📊 [SERVER] KIPRIS advanced search summary: ${allResults.length} total, ${uniqueResults.length} unique`);

  return uniqueResults;
}

/**
 * 🚀 KIPRIS 자유 검색 API 호출
 */
async function performKiprisFreeSearch(
  trademark: string,
  kiprisKey: string
): Promise<KiprisTrademarkInfo[]> {
  // Free Search 실행
  
  const allResults: KiprisTrademarkInfo[] = [];
  
  // HTTPS를 먼저 시도하고, 실패하면 HTTP 시도
  const baseUrls = [
    "https://plus.kipris.or.kr/openapi/rest/trademarkInfoSearchService/freeSearchInfo",
    "http://plus.kipris.or.kr/openapi/rest/trademarkInfoSearchService/freeSearchInfo",
  ];

  for (const baseUrl of baseUrls) {
    // Free search URL 시도 중
    
    try {
      let url = `${baseUrl}?accessKey=${kiprisKey}`;
      url += `&word=${encodeURIComponent(trademark)}`;
      url += `&docsStart=1&docsCount=100`; // 결과 수 제한

      // Free search API 호출

      const controller = new AbortController();
      const timeoutId = setTimeout(() => {
        console.log(`⏰ [SERVER] Request timeout for KIPRIS free search`);
        controller.abort();
      }, 60000); // 60초 타임아웃

      const response = await fetch(url, {
        method: "GET",
        headers: {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
          "Accept": "application/xml, text/xml, */*",
          "Accept-Language": "ko-KR,ko;q=0.9,en;q=0.8",
          "Accept-Encoding": "gzip, deflate, br",
          "Cache-Control": "no-cache",
          "Connection": "keep-alive",
          "Upgrade-Insecure-Requests": "1"
        },
        signal: controller.signal,
      });

      clearTimeout(timeoutId);

      console.log(`📡 [SERVER] Free search response status: ${response.status}`);

      if (!response.ok) {
        console.error(`❌ [SERVER] Free search HTTP error: ${response.status}`);
        continue;
      }

      const xmlText = await response.text();
      // Free search XML 응답 수신됨

      if (!xmlText || xmlText.length < 50) {
        console.warn(`⚠️ [SERVER] Empty or too short free search response`);
        continue;
      }

      // XML 파싱 및 데이터 추출 (자유 검색용)
      const items = parseKiprisXMLForFreeSearch(xmlText);
      console.log(`📊 [SERVER] Parsed ${items.length} items from free search XML`);

      if (items.length > 0) {
        allResults.push(...items);
        console.log(`✅ [SERVER] Free search got ${items.length} results`);
        break; // 첫 번째 URL에서 결과를 얻으면 충분
      }

      // API 호출 간격 (필요시)
      await new Promise((resolve) => setTimeout(resolve, 1000));

    } catch (error) {
      console.error(`❌ [SERVER] Free search request failed:`, error);

      if (error instanceof Error && error.name === "AbortError") {
        console.error(`⏰ [SERVER] Free search request timeout`);
      }

      continue; // 다음 URL 시도
    }
  }

  console.log(`📊 [SERVER] Free search summary: ${allResults.length} total results`);
  return allResults;
}

