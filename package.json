{
  "name": "my-v0-project",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "predev": "kill-port 5001 || true",
    "vector:install": "python3 -m pip install -r vectorDB/requirements.txt",
    "vector:dev": "python3 vectorDB/app.py",
    "build": "next build",
    "dev": "next dev -p 5001",
    "lint": "next lint",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "types:generate": "npx supabase gen types typescript --local > src/types/supabase-generated.ts",
    "security:audit": "npm audit --audit-level=moderate",
    "security:test": "npm test -- security-basic",
    "security:full": "npm run security:audit && npm run security:test && npm run lint",
    "migrate": "tsx tools/migrations/scripts/run-migrations.ts",
    "migrate:status": "tsx tools/migrations/scripts/run-migrations.ts status",
    "migrate:rollback": "tsx tools/migrations/scripts/run-migrations.ts rollback",
    "migrate:supabase": "tsx tools/migrations/scripts/run-migrations.ts supabase",
    "migrate:upstash": "tsx tools/migrations/scripts/run-migrations.ts upstash",
    "db:reset": "npm run migrate:rollback 1 && npm run migrate",
    "db:seed": "tsx tools/migrations/scripts/seed-data.ts",
    "swagger:validate": "tsx scripts/swagger-validate.ts",
    "swagger:generate": "tsx scripts/swagger-generate.ts",
    "swagger:generate-all": "tsx scripts/swagger-generate-all.ts",
    "swagger:changelog": "tsx scripts/swagger-changelog.ts",
    "swagger:diff": "tsx scripts/swagger-diff.ts",
    "swagger:stats": "tsx scripts/swagger-stats.ts",
    "swagger:breaking-changes": "tsx scripts/swagger-breaking-changes.ts",
    "swagger:test-endpoints": "tsx scripts/swagger-test-endpoints.ts",
    "swagger:deploy-docs": "tsx scripts/swagger-deploy-docs.ts"
  },
